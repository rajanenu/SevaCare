{
  "name": "sevacare-frontend",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:local": "CI=1 expo start --port 8087",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:export": "expo export --platform web",
    "web:preview": "npm run web:export && python3 -m http.server 8087 -d dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/poppins": "^0.4.1",
    "@react-native-picker/picker": "^2.11.4",
    "expo": "~55.0.8",
    "expo-camera": "~55.0.10",
    "expo-document-picker": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-linear-gradient": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "private": true
