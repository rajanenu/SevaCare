# SevaCare Production Environment Template

# App
APP_ENV=production
SERVER_PORT=8081
FRONTEND_PORT=8087

# API URLs
PUBLIC_API_BASE_URL=https://api.sevacare.example.com/api/v1
EXPO_PUBLIC_API_BASE_URL=https://api.sevacare.example.com/api/v1

# Database (Managed PostgreSQL recommended)
SPRING_DATASOURCE_URL=jdbc:postgresql://db.sevacare.example.com:5432/seva_care
SPRING_DATASOURCE_USERNAME=sevacare_app
SPRING_DATASOURCE_PASSWORD=CHANGE_ME

# Security
SEVACARE_JWT_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET

# Runtime
JAVA_OPTS=-Xms512m -Xmx1024m
LOG_LEVEL=INFO
