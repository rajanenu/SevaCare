# SevaCare Production Environment Template
# Copy to a secret store (GCP Secret Manager, etc.) — never commit real values.
# Variable names match exactly what the Spring app reads (see application.yml).

# Runtime
SPRING_PROFILES_ACTIVE=production
PORT=8080
JAVA_OPTS=-Xms512m -Xmx1024m

# Database (managed PostgreSQL recommended)
SEVACARE_DB_URL=jdbc:postgresql://db.sevacare.example.com:5432/seva_care
SEVACARE_DB_USERNAME=sevacare_app
SEVACARE_DB_PASSWORD=CHANGE_ME

# Security
SEVACARE_AUTH_SECRET=CHANGE_ME_TO_LONG_RANDOM_SECRET
# Comma-separated allowed web origins for CORS (no wildcards in production).
SEVACARE_CORS_ORIGINS=https://app.sevacare.example.com

# Frontend web build — full API base URL baked in at build time.
API_BASE_URL=https://api.sevacare.example.com/api/v1
