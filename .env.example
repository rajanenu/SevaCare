# SevaCare Environment Configuration

# ════════════════════════════════════════════════════════════════
# ENVIRONMENT: local | staging | production
# ════════════════════════════════════════════════════════════════
ENVIRONMENT=local
APP_NAME=SevaCare
APP_VERSION=1.0.0

# ════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sevacare
DB_USER=postgres
DB_PASSWORD=postgres
DB_URL=jdbc:postgresql://localhost:5432/sevacare

# ════════════════════════════════════════════════════════════════
# BACKEND CONFIGURATION
# ════════════════════════════════════════════════════════════════
BACKEND_HOST=localhost
BACKEND_PORT=8081
BACKEND_URL=http://localhost:8081
BACKEND_API_BASE=/api/v1

# ════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION
# ════════════════════════════════════════════════════════════════
FRONTEND_HOST=localhost
FRONTEND_PORT=8087
FRONTEND_URL=http://localhost:8087
EXPO_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1

# ════════════════════════════════════════════════════════════════
# NETWORK ACCESS (for accessing via machine IP)
# Set this to your local machine IP for network access
# Example: 192.168.1.100
# ════════════════════════════════════════════════════════════════
LOCAL_IP=192.168.1.100

# ════════════════════════════════════════════════════════════════
# DEPLOYMENT CONFIGURATION
# ════════════════════════════════════════════════════════════════
JAVA_VERSION=21
NODE_VERSION=20.x
MAVEN_VERSION=3.9.x

# ════════════════════════════════════════════════════════════════
# BUILD CONFIGURATION
# ════════════════════════════════════════════════════════════════
SKIP_TESTS=true
BUILD_THREADS=4
BUNDLE_SIZE_LIMIT=1000

# ════════════════════════════════════════════════════════════════
# LOGGING
# ════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
DEBUG_MODE=false

# ════════════════════════════════════════════════════════════════
# SECURITY (Update for production)
# ════════════════════════════════════════════════════════════════
JWT_SECRET=dev-secret-key-change-in-production
API_KEY=dev-api-key-change-in-production
